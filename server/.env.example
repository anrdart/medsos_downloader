# Shared config for the ANR Saver backend (systemd EnvironmentFile).
# Copy to /opt/anrsaver/.env and edit. Must match lib/src/core/utils/api_config.dart.

# Public IP of this VPS (used by docker-compose for Cobalt's API_URL)
VPS_IP=CHANGE_ME

# Secret shared with the app (ApiConfig.ytdlpApiKey / cookieSyncApiKey)
API_KEY=wrIShnwgKDOvpNs7jCj30SweholNPjAo

# Cobalt's cookies.json (mounted read-only into the container)
COOKIE_PATH=/opt/anrsaver/cookies.json

# Per-platform Netscape cookie files for yt-dlp (shared by both services)
COOKIE_DIR=/opt/anrsaver/cookies

# Where yt-dlp writes merged files before serving them
DOWNLOAD_DIR=/opt/anrsaver/downloads

# Docker container name for Cobalt (cookie_sync restarts it on cookie change)
COBALT_CONTAINER=cobalt
