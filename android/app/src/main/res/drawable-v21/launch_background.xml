<?xml version="1.0" encoding="utf-8"?>
<!-- Matte black splash screen with EL-Saver logo for API 21+ -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Matte black gradient background -->
    <item>
        <shape>
            <gradient
                android:startColor="#1E1E1E"
                android:endColor="#121212"
                android:angle="315"
                android:type="linear" />
        </shape>
    </item>

    <!-- EL-Saver logo with gradient circular background -->
    <item>
        <layer-list>
            <!-- Gradient circle background -->
            <item android:gravity="center">
                <shape android:shape="oval">
                    <gradient
                        android:startColor="#1A7C3AED"
                        android:endColor="#0D7C3AED"
                        android:angle="315"
                        android:type="linear" />
                    <stroke
                        android:width="2dp"
                        android:color="#4D7C3AED" />
                    <size android:width="180dp" android:height="180dp" />
                </shape>
            </item>
            <!-- Logo centered in the circle -->
            <item android:gravity="center">
                <bitmap
                    android:gravity="center"
                    android:src="@drawable/el_logo" />
            </item>
        </layer-list>
    </item>
</layer-list>
